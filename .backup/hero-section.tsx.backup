          style={{
            pointerEvents: 'none',
            userSelect: 'none',
            width: '100%',
            height: '100%',
            position: 'relative'
          }}
          onMouseDown={(e) => e.preventDefault()}
          onMouseMove={(e) => e.preventDefault()}
